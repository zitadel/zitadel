NEXT_PUBLIC_BASE_PATH=/ui/v2/login
EMAIL_VERIFICATION=false
ZITADEL_API_URL=http://localhost:8080
ZITADEL_SERVICE_USER_TOKEN_FILE=../../login-client.pat

# Whether ui_locales from OAuth requests should always override the language cookie.
# When set to "true", the language from ui_locales will always be used.
# When unset or set to "false", ui_locales only sets the language if no cookie exists (preserves user's manual selection).
# ZITADEL_UI_LOCALES_OVERRIDE_COOKIE=false
