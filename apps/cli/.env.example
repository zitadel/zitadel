# ZITADEL CLI – environment variable reference
# Copy this file to .env and fill in the values for your setup.
# The CLI automatically loads .env from the current working directory.

# ─────────────────────────────────────────────
# Required: the ZITADEL instance base URL
# ─────────────────────────────────────────────
ZITADEL_INSTANCE=https://your-instance.zitadel.cloud

# ─────────────────────────────────────────────
# Auth option 1 – Personal Access Token (PAT)
# Create one under: Console → Service Users → New service user → PAT tab
# When set, all commands use this token directly (no browser login needed).
# ─────────────────────────────────────────────
ZITADEL_TOKEN=your-personal-access-token

# ─────────────────────────────────────────────
# Auth option 2 – Interactive OIDC PKCE login
# Use this instead of ZITADEL_TOKEN.
# Run: zitadel login --instance $ZITADEL_INSTANCE --client-id $ZITADEL_CLIENT_ID
# Requires a Native or User Agent application in ZITADEL with
# http://localhost as an allowed redirect URI.
# After login the token is stored in ~/.config/zitadel/config.toml.
# ─────────────────────────────────────────────
# ZITADEL_CLIENT_ID=your-native-app-client-id

# ─────────────────────────────────────────────
# Optional: override the config directory
# Default: $HOME/.config (Linux/macOS) / %AppData% (Windows)
# ─────────────────────────────────────────────
# XDG_CONFIG_HOME=/path/to/custom/config/dir
