{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@zitadel/cli",
  "projectType": "application",
  "targets": {
    "build": {
      "description": "Builds the ZITADEL CLI binary.",
      "command": "bash -c 'cd apps/cli && go build -ldflags \"-X github.com/zitadel/zitadel/cmd/build.version=$(git describe --tags --always 2>/dev/null || echo dev) -X github.com/zitadel/zitadel/cmd/build.date=$(date -u +%Y-%m-%dT%H:%M:%SZ)\" -o ../../.artifacts/bin/$(go env GOOS)/$(go env GOARCH)/zitadel-cli .'",
      "cache": true,
      "inputs": [
        "{projectRoot}/**/*.go",
        "{projectRoot}/go.mod",
        "{projectRoot}/go.sum",
        "{workspaceRoot}/pkg/grpc/**/*.go"
      ],
      "outputs": [
        "{workspaceRoot}/.artifacts/bin/*/*/zitadel-cli"
      ]
    },
    "lint": {
      "description": "Runs go vet on the CLI.",
      "command": "cd apps/cli && go vet ./...",
      "cache": true,
      "inputs": [
        "{projectRoot}/**/*.go",
        "{projectRoot}/go.mod",
        "{projectRoot}/go.sum",
        "{workspaceRoot}/pkg/grpc/**/*.go"
      ]
    },
    "test": {
      "description": "Runs CLI unit tests.",
      "command": "cd apps/cli && go test ./...",
      "cache": true,
      "inputs": [
        "{projectRoot}/**/*.go",
        "{projectRoot}/go.mod",
        "{projectRoot}/go.sum",
        "{workspaceRoot}/pkg/grpc/**/*.go"
      ]
    }
  }
}
