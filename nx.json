{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "nxCloudId": "688a9021d48dce0efe0f119f",
  "workspaceLayout": {
    "libsDir": "packages"
  },
  "parallel": 1,
  "tui": {
    "enabled": true
  },
  "maxCacheSize": "5GB",
  "namedInputs": {
    "sharedGlobals": [
      "{workspaceRoot}/nx.json"
    ],
    "goGlobals": [
      "sharedGlobals",
      "{workspaceRoot}/go.mod",
      "{workspaceRoot}/go.sum"
    ],
    "jsGlobals": [
      "sharedGlobals",
      "{workspaceRoot}/pnpm-lock.yaml"
    ],
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.*",
      "!{projectRoot}/**/*.test.*",
      "!{projectRoot}/**/*_test.go",
      "!{projectRoot}/**/integration_test/**/*",
      "!{projectRoot}/**/cypress/**/*",
      "!{projectRoot}/**/__tests__/**/*"
    ]
  },
  "targetDefaults": {
    "nx:run-commands": {
      "options": {
        "env": {
          "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0",
          "ENABLE_EXPERIMENTAL_COREPACK": "1"
        }
      }
    },
    "generate": {
      "cache": true,
      "inputs": [
        "default"
      ]
    },
    "build": {
      "cache": true,
      "inputs": [
        "production"
      ],
      "dependsOn": [
        "^build",
        "generate"
      ]
    },
    "lint": {
      "inputs": [
        "production"
      ],
      "cache": true
    },
    "check-links": {
      "inputs": [
        "default"
      ],
      "cache": true
    },
    "test": {
      "inputs": [
        "default"
      ],
      "cache": true
    },
    "test-unit": {
      "inputs": [
        "default"
      ],
      "cache": true
    },
    "test-integration": {
      "inputs": [
        "default"
      ],
      "cache": true
    }
  }
}
