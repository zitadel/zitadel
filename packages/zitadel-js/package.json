{
  "name": "@zitadel/zitadel-js",
  "version": "0.1.0",
  "license": "MIT",
  "description": "ZITADEL JavaScript SDK — isomorphic core",
  "publishConfig": { "access": "public" },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist/**"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" },
    "./node": { "types": "./dist/token.d.ts", "import": "./dist/token.js", "require": "./dist/token.cjs" },
    "./webhooks": { "types": "./dist/webhooks.d.ts", "import": "./dist/webhooks.js", "require": "./dist/webhooks.cjs" }
  },
  "scripts": {
    "generate": "buf generate buf.build/zitadel/zitadel",
    "build": "pnpm generate && tsup",
    "lint-check-eslint": "eslint 'src/**/*.ts*'",
    "lint-check-knip": "knip",
    "test-unit": "vitest --run",
    "clean": "rm -rf node_modules dist src/generated"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "jose": "^5.10.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.34.0",
    "@types/node": "^24.10.9",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^8.57.1",
    "knip": "^5.82.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
