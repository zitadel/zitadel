# ZITADEL SDK — Environment Variables
# ====================================
# Copy this file to `.env.local` (Next.js) or `.env` and fill in your values.
#
# Not every variable is needed — only the sections relevant to your
# integration pattern. See the inline links for full documentation.

# ---------------------------------------------------------------------
# OIDC — Add login to your app via redirect
# ---------------------------------------------------------------------
# Use this when your app redirects users to ZITADEL (or a custom login
# UI) for authentication and receives tokens back via callback.
#
# Docs: https://zitadel.com/docs/guides/integrate/login-ui/oidc-standard

# The ZITADEL issuer URL (your instance).
ZITADEL_ISSUER_URL=https://my-instance.zitadel.cloud

# The OIDC client ID from your ZITADEL project application.
ZITADEL_CLIENT_ID=

# The exact callback URL registered in your ZITADEL application.
ZITADEL_CALLBACK_URL=http://localhost:3000/api/auth/callback

# Secret used to encrypt session cookies. Must be at least 32 characters.
# Generate with: openssl rand -base64 32
ZITADEL_COOKIE_SECRET=

# URL to redirect to after logout (optional).
# ZITADEL_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# ---------------------------------------------------------------------
# API — Call ZITADEL v2 APIs / Session API for custom login
# ---------------------------------------------------------------------
# Use this section when making server-side calls to the ZITADEL API,
# whether for management tasks or for building a custom login UI with
# the Session API.
#
# Docs (API access):  https://zitadel.com/docs/guides/integrate/zitadel-apis/access-zitadel-apis
# Docs (Session API): https://zitadel.com/docs/guides/integrate/login-ui/username-password

# The ZITADEL API base URL (usually same as ZITADEL_ISSUER_URL).
ZITADEL_API_URL=https://my-instance.zitadel.cloud

# Authentication — choose one method:
#
# Option 1: Personal Access Token (simplest)
ZITADEL_SERVICE_USER_TOKEN=
#
# Option 2: Private Key JWT (more secure)
# ZITADEL_SERVICE_USER_KEY_ID=
# ZITADEL_SERVICE_USER_ID=
# ZITADEL_SERVICE_USER_PRIVATE_KEY=

# ---------------------------------------------------------------------
# Actions — Receive ZITADEL Actions v2 webhooks
# ---------------------------------------------------------------------
# Configure depending on the payload type set on the ZITADEL target.
#
# Docs: https://zitadel.com/docs/guides/integrate/actions/testing-request-signature

# Optional payload mode used by SDK wrappers (`json`, `jwt`, or `jwe`).
# Defaults to `json` when unset.
# ZITADEL_WEBHOOK_PAYLOAD_TYPE=json

# JSON payload type (HMAC-SHA256 signature verification)
# The signingKey returned when you created the target in ZITADEL.
ZITADEL_WEBHOOK_SECRET=

# JWT payload type — verify signed webhooks against ZITADEL's JWKS.
# ZITADEL_WEBHOOK_JWKS_ENDPOINT=https://my-instance.zitadel.cloud/oauth/v2/keys

# JWE payload type — decrypt webhook with your private key, then verify JWT.
# The PEM-encoded private key whose public key was uploaded to the target.
# ZITADEL_WEBHOOK_JWE_PRIVATE_KEY=
