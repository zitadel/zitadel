{
  "name": "@zitadel/nextjs",
  "version": "0.1.0",
  "license": "MIT",
  "description": "ZITADEL Next.js SDK — App Router integration with OIDC lifecycle",
  "publishConfig": { "access": "public" },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "zitadel-nextjs": "./dist/cli.cjs"
  },
  "files": ["dist/**"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" },
    "./auth": { "types": "./dist/auth/index.d.ts", "import": "./dist/auth/index.js", "require": "./dist/auth/index.cjs" },
    "./auth/oidc": { "types": "./dist/auth/oidc.d.ts", "import": "./dist/auth/oidc.js", "require": "./dist/auth/oidc.cjs" },
    "./auth/session": { "types": "./dist/auth/session.d.ts", "import": "./dist/auth/session.js", "require": "./dist/auth/session.cjs" },
    "./auth/bearer-token": { "types": "./dist/api/bearer-token.d.ts", "import": "./dist/api/bearer-token.js", "require": "./dist/api/bearer-token.cjs" },
    "./middleware": { "types": "./dist/middleware.d.ts", "import": "./dist/middleware.js", "require": "./dist/middleware.cjs" },
    "./server-action": { "types": "./dist/server-action.d.ts", "import": "./dist/server-action.js", "require": "./dist/server-action.cjs" },
    "./api": { "types": "./dist/api.d.ts", "import": "./dist/api.js", "require": "./dist/api.cjs" },
    "./api/bearer-token": { "types": "./dist/api/bearer-token.d.ts", "import": "./dist/api/bearer-token.js", "require": "./dist/api/bearer-token.cjs" },
    "./actions/webhook": { "types": "./dist/webhook.d.ts", "import": "./dist/webhook.js", "require": "./dist/webhook.cjs" },
    "./webhook": { "types": "./dist/webhook.d.ts", "import": "./dist/webhook.js", "require": "./dist/webhook.cjs" }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint-check-eslint": "eslint 'src/**/*.ts*'",
    "lint-check-knip": "knip",
    "test-unit": "vitest --run",
    "clean": "rm -rf node_modules dist"
  },
  "dependencies": {
    "@zitadel/react": "workspace:*",
    "@zitadel/zitadel-js": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.10.9",
    "@types/react": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^8.57.1",
    "knip": "^5.82.1",
    "next": "^15.3.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
