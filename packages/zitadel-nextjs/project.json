{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "namedInputs": { "sources": ["{projectRoot}/src/**/*"] },
  "targets": {
    "build": {
      "description": "Builds @zitadel/nextjs",
      "inputs": ["default", "{workspaceRoot}/pnpm-lock.yaml"],
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build"]
    },
    "test": { "dependsOn": ["test-unit"] }
  }
}
